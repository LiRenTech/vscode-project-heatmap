{
  "name": "project-heatmap",
  "displayName": "Project Heatmap",
  "description": "在 VS Code 中以矩形树图（Treemap）展示项目文件热力图：面积代表文件行数，颜色代表 Git 提交触达次数。",
  "version": "0.0.1",
  "author": "LiRenTech",
  "icon": "media/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LiRenTech/vscode-project-heatmap.git"
  },
  "homepage": "https://github.com/LiRenTech/vscode-project-heatmap",
  "bugs": {
    "url": "https://github.com/LiRenTech/vscode-project-heatmap/issues"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "project-heatmap.showHeatmap",
        "category": "Project Heatmap",
        "title": "显示项目文件热力图 (showHeatmap)"
      }
    ],
    "configuration": {
      "title": "Project Heatmap",
      "properties": {
        "projectHeatmap.excludePatterns": {
          "type": "array",
          "default": [
            "pnpm-lock.yaml",
            "Cargo.lock",
            "yarn.lock",
            "package-lock.json",
            "npm-shrinkwrap.json"
          ],
          "items": {
            "type": "string"
          },
          "description": "热力图默认排除的文件模式。支持文件名或简单通配符，用户可以继续追加。"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.48.1",
    "eslint": "^9.39.1",
    "esbuild": "^0.27.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
